# ===== MySQL =====
DB_URL=jdbc:mysql://your-mysql-host:3306/ry-vue?useUnicode=true&characterEncoding=utf8&zeroDateTimeBehavior=convertToNull&useSSL=true&serverTimezone=GMT%2B8
DB_USERNAME=your_mysql_username
DB_PASSWORD=your_mysql_password

# ===== Redis =====
REDIS_HOST=your-redis-host
REDIS_PORT=6379
REDIS_DATABASE=0
REDIS_PASSWORD=your_redis_password

# ===== Token =====
TOKEN_SECRET=your_strong_token_secret

# ===== Log Path =====
LOG_PATH=/home/ruoyi/logs
